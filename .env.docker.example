# ── Docker / Portainer environment variables ──────────────────────────────────
# Copy this to .env and fill in your values.
# In Portainer: paste these into Stack > Environment variables.

# Your existing MariaDB server on the network
DB_HOST=192.168.x.x
DB_PORT=3306
DB_USER=training_user
DB_PASSWORD=choose_a_strong_password
DB_NAME=training_plan

# Port the app is exposed on (nginx). Default: 80
# Change to e.g. 8080 if port 80 is already in use.
APP_PORT=80

# Strava OAuth (optional — app works without this)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Set to your server's public/LAN address:
STRAVA_REDIRECT_URI=http://YOUR_SERVER_IP/auth/strava/callback

# Anthropic Claude API key (optional — coach tab needs this)
ANTHROPIC_API_KEY=

# URL the frontend is served from — used for Strava OAuth redirect back
CLIENT_URL=http://YOUR_SERVER_IP
